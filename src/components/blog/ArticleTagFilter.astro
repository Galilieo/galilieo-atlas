---
import type { CollectionEntry } from 'astro:content';

interface Props {
  articles: CollectionEntry<'blog'>[];
}

const { articles } = Astro.props;
const tagCounts = new Map<string, number>();
articles.forEach((article) => {
  new Set(article.data.tags).forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  });
});
const tags = [...tagCounts.entries()].sort(
  ([tagA, countA], [tagB, countB]) => countB - countA || tagA.localeCompare(tagB, 'zh-CN'),
);
---

<section class="article-filter" data-article-filter aria-labelledby="article-filter-title">
  <div class="article-filter__heading">
    <div>
      <p class="article-filter__eyebrow">Tag Index</p>
      <h2 id="article-filter-title">按文章标签浏览</h2>
    </div>
    <p class="article-filter__status" data-article-filter-status aria-live="polite">
      显示全部 {articles.length} 篇文章
    </p>
  </div>
  <div class="article-filter__options" role="group" aria-label="按标签筛选文章">
    <button
      class="article-filter__button is-active"
      type="button"
      data-article-filter-value="*"
      aria-pressed="true"
    >
      <span>全部文章</span>
      <span class="article-filter__count">{String(articles.length).padStart(2, '0')}</span>
    </button>
    {
      tags.map(([tag, count]) => (
        <button
          class="article-filter__button"
          type="button"
          data-article-filter-value={tag}
          aria-pressed="false"
        >
          <span>{tag}</span>
          <span class="article-filter__count">{String(count).padStart(2, '0')}</span>
        </button>
      ))
    }
  </div>
</section>
