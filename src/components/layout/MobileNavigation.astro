---
import { isNavigationPathActive, siteConfig } from '../../config/site';

// 用途：输出桌面与移动端共用的主导航；数据来源：src/config/site.ts；后续统一修改配置。
const currentPath = Astro.url.pathname;
---

<nav class="site-nav" id="site-navigation" aria-label="主导航">
  {
    siteConfig.navigation.map((item) => {
      const isActive = isNavigationPathActive(item.href, currentPath);
      return (
        <a
          class:list={{ 'is-active': isActive }}
          href={item.href}
          aria-current={isActive ? 'page' : undefined}
        >
          {item.label}
        </a>
      );
    })
  }
</nav>
