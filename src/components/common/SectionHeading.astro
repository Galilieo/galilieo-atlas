---
interface Props {
  eyebrow?: string;
  title: string;
  titleLines?: readonly string[];
  description?: string;
}

const { eyebrow, title, titleLines, description } = Astro.props;
---

<header class="section-heading reveal">
  <div>
    {eyebrow && <p class="section-kicker">{eyebrow}</p>}
    <h1 class="page-title">
      {titleLines ? titleLines.map((line) => <span class="page-title__line">{line}</span>) : title}
    </h1>
  </div>
  {description && <p>{description}</p>}
</header>
