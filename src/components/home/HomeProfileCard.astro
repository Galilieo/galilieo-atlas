---
import { getCollection } from 'astro:content';
import { siteConfig } from '../../config/site';
import { homeProfile } from '../../data/home';

const workCount = (await getCollection('projects')).length;
const noteCount = (await getCollection('blog')).filter((article) => !article.data.draft).length;
---

<section class="home-profile dashboard-card reveal" id="profile" aria-labelledby="profile-title">
  <a
    class="home-profile__about-link"
    href="/about/"
    aria-label={`查看 ${siteConfig.author.name} 的完整个人资料`}
  >
    <span class="home-profile__about-cue">
      查看完整档案 <span aria-hidden="true">→</span>
    </span>
  </a>

  <div class="home-profile__content">
    <div class="home-profile__identity">
      <div class="home-profile__avatar" aria-hidden="true">G</div>
      <div class="home-profile__copy">
        <p class="home-profile__eyebrow">Keeper profile · 001</p>
        <h1 id="profile-title">{siteConfig.author.name}</h1>
        <p class="home-profile__role">{homeProfile.role}</p>
        <p class="home-profile__summary">{homeProfile.summary}</p>
      </div>
    </div>

    <div class="home-profile__footer">
      <div class="home-profile__counts" aria-label="内容概览">
        <a
          class="home-profile__count"
          href="/projects/"
          aria-label={`查看全部 ${workCount} 个项目`}
        >
          <strong>{String(workCount).padStart(2, '0')}</strong>
          <span>Works</span>
        </a>
        <a class="home-profile__count" href="/blog/" aria-label={`查看全部 ${noteCount} 篇笔记`}>
          <strong>{String(noteCount).padStart(2, '0')}</strong>
          <span>Notes</span>
        </a>
      </div>

      <nav class="home-profile__contacts" aria-label="快速联系">
        <a
          class="home-profile__contact"
          href={siteConfig.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="访问 Galilieo 的 GitHub"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M9 19c-4 1.2-4-2-5-2.5M14 22v-3.5c0-1 .1-1.5-.5-2 3 0 6-.8 6-4.5a3.5 3.5 0 0 0-1-2.5 3.3 3.3 0 0 0-.1-2.5s-.8-.3-2.7 1a9.3 9.3 0 0 0-5 0C8.8 6.7 8 7 8 7a3.3 3.3 0 0 0-.1 2.5A3.5 3.5 0 0 0 7 12c0 3.7 3 4.5 6 4.5-.4.4-.6.8-.6 1.5V22"
            ></path>
          </svg>
        </a>
        <a
          class="home-profile__contact"
          href={`mailto:${siteConfig.email}`}
          aria-label="发送邮件给 Galilieo"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            <path d="m4 7 8 6 8-6"></path>
          </svg>
        </a>
        <a
          class="home-profile__contact"
          href={siteConfig.heartIsland}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="访问 Heart Island 心屿"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="8"></circle>
            <path d="M5 14c3-2 5-2 7 0s4 2 7 0"></path>
          </svg>
        </a>
      </nav>
    </div>
  </div>
</section>
