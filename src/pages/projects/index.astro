---
import { getCollection } from 'astro:content';
import SectionHeading from '../../components/common/SectionHeading.astro';
import ProjectCard from '../../components/project/ProjectCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="项目 — Galilieo"
  description="Galilieo 的真实项目、实习项目和持续开发记录。"
  canonicalPath="/projects/"
>
  <main class="page-main interior-page interior-page--projects" id="main-content">
    <SectionHeading
      eyebrow="Projects"
      title="做过的项目，解决过的问题。"
      description="记录我做过、参与过和仍在推进的项目。"
    />
    <div class="project-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </main>
</BaseLayout>
