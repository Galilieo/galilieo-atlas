---
import type { MarkdownHeading } from 'astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import ArticleMeta from '../components/blog/ArticleMeta.astro';
import ArticleNavigation from '../components/blog/ArticleNavigation.astro';
import ArticleReadingNavigation from '../components/blog/ArticleReadingNavigation.astro';
import ArticleRecommendations from '../components/blog/ArticleRecommendations.astro';
import TagList from '../components/common/TagList.astro';
import { siteConfig } from '../config/site';
import { getBlogCover } from '../lib/blog-cover';
import BaseLayout from './BaseLayout.astro';

interface Props {
  article: CollectionEntry<'blog'>;
  previous?: CollectionEntry<'blog'>;
  next?: CollectionEntry<'blog'>;
  recommendations: CollectionEntry<'blog'>[];
  headings: MarkdownHeading[];
}

const { article, previous, next, recommendations, headings } = Astro.props;
const artwork = getBlogCover(article);
const coverAlt = artwork.key === 'custom' ? `${article.data.title}封面` : '';
const title = `${article.data.title} — ${siteConfig.author.name}`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  description: article.data.description,
  datePublished: article.data.publishedAt,
  dateModified: article.data.updatedAt ?? article.data.publishedAt,
  author: { '@type': 'Person', name: siteConfig.author.name },
  inLanguage: 'zh-CN',
  mainEntityOfPage: new URL(`/notes/${article.id}/`, siteConfig.url).toString(),
};
---

<BaseLayout
  title={title}
  description={article.data.description}
  canonicalPath={`/notes/${article.id}/`}
  type="article"
  publishedTime={article.data.publishedAt}
  modifiedTime={article.data.updatedAt}
  jsonLd={jsonLd}
>
  <main class="page-main interior-page interior-detail" id="main-content">
    <div class="article-reading-layout">
      <article class="article-page">
        <section class="article-page__hero reveal" data-article-hero>
          <div class="article-page__cover" data-article-cover>
            <Image
              src={artwork.image}
              alt={coverAlt}
              class:list={[
                'article-page__cover-image',
                `article-page__cover-image--${artwork.key}`,
              ]}
              style={`object-position: ${artwork.position}`}
              widths={[480, 720, 960, 1280]}
              sizes="(max-width: 1100px) calc(100vw - 72px), 860px"
              loading="eager"
              decoding="async"
            />
          </div>
          <header class="page-header">
            <a class="article-page__back" href="/notes/" data-article-back-link>
              <span class="article-page__back-icon" aria-hidden="true">←</span>
              <span>返回博客</span>
            </a>
            <p class="section-kicker">Notes / {article.data.category}</p>
            <h1>{article.data.title}</h1>
            <p>{article.data.description}</p>
            <ArticleMeta
              category={article.data.category}
              publishedAt={article.data.publishedAt}
              updatedAt={article.data.updatedAt}
              readingTime={article.data.readingTime}
            />
            <TagList items={article.data.tags} label="文章标签" />
          </header>
        </section>
        <ArticleReadingNavigation variant="mobile" headings={headings} />
        <div class="prose" data-article-body><slot /></div>
        <ArticleNavigation previous={previous} next={next} />
        <ArticleRecommendations articles={recommendations} variant="mobile" />
      </article>
      <ArticleReadingNavigation
        variant="desktop"
        headings={headings}
        recommendations={recommendations}
      />
    </div>
  </main>
</BaseLayout>
